{
  "name": "bot0",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier . --write",
    "check": "pnpm lint && pnpm build"
  },
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^24.3.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.35.1"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "prettier --write"
    ]
  }
}
